generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Cuber {
  id         String @id @default(cuid())

  googleId   String @unique
  email      String @unique

  name       String?
  pictureURL String?

  publicId   String @unique
  
  puzzles    Puzzle[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Puzzle {
  id       String @id @default(cuid())

  name     String
  currMain String?

  cuberId  String
  cuber    Cuber @relation(fields: [cuberId], references: [id], onDelete: Cascade)

  records  PBest[]

  @@unique([cuberId, name])
}

model PBest {
  id        String @id @default(cuid())

  category  String

  scoreJson String
  
  setOn     DateTime?
  setInComp Boolean @default(false)

  puzzleId  String
  puzzle    Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  @@unique([puzzleId, category])
}

model Report {
  id              String @id @unique @default(cuid())
  targetPublicId  String
  where           String
  createdAt       DateTime @default(now())
}